OTX_API_KEY=
ABUSEIPDB_API_KEY=
VIRUSTOTAL_API_KEY=

# Optional overrides
TIP_CONFIDENCE_THRESHOLD=60
TIP_OTX_LIMIT=100
TIP_OTX_MAX_PAGE=5
